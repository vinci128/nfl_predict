# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Optional: enables "Ask Claude" button in the draft UI
ANTHROPIC_API_KEY=sk-ant-...

# NFL Fantasy live sync — required for the NFL Sync button and nfl-sync command
# League ID is the 8-digit number in the URL: fantasy.nfl.com/league/XXXXXXXX
# Team ID is your slot number (1–12) — leave blank to auto-detect from username
NFL_FANTASY_USERNAME=you@email.com
NFL_FANTASY_PASSWORD=
NFL_FANTASY_LEAGUE_ID=
NFL_FANTASY_TEAM_ID=
