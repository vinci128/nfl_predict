# NFL Fantasy Agent Configuration
# Copy this file to .env and fill in your values

# LLM backend: "ollama" (local, free) or "claude" (Anthropic API, paid)
LLM_BACKEND=ollama

# --- Ollama settings (used when LLM_BACKEND=ollama) ---
# Model to use. For RX 7900 XTX (24GB): qwen2.5:32b is the best option.
# Pull it first: ollama pull qwen2.5:32b
OLLAMA_MODEL=qwen2.5:32b
OLLAMA_HOST=http://localhost:11434

# --- Claude settings (used when LLM_BACKEND=claude) ---
# Anthropic API key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# NFL.com account credentials
NFL_EMAIL=your@email.com
NFL_PASSWORD=yourpassword

# Your NFL.com Fantasy league ID
# Find it in the URL: fantasy.nfl.com/league/{LEAGUE_ID}
NFL_LEAGUE_ID=123456

# Your team ID within the league
# Find it in the URL: fantasy.nfl.com/league/{LEAGUE_ID}/team/{TEAM_ID}
NFL_TEAM_ID=1

# Set to "true" to run the browser headless (no visible window)
# Set to "false" (default) to see the browser — useful for debugging
NFL_BROWSER_HEADLESS=false
